# ── CRITICAL (app won't function without these) ──────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── AUTHENTICATION ────────────────────────────────────────────
ENGINE_PASSWORD=your-login-password

# ── INSTAGRAM / META ─────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-ig-token
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret

# ── INTEGRATIONS (features degrade gracefully if missing) ────
MANYCHAT_API_KEY=your-manychat-api-key
FLODESK_API_KEY=your-flodesk-api-key
APIFY_TOKEN=your-apify-token
VIZARD_API_KEY=your-vizard-api-key
PERPLEXITY_API_KEY=your-perplexity-key
