# ── CRITICAL (app won't function without these) ──────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── AUTHENTICATION ────────────────────────────────────────────
ENGINE_PASSWORD=your-login-password

# ── INSTAGRAM / META ─────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-ig-token
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret

# ── INTEGRATIONS (features degrade gracefully if missing) ────
MANYCHAT_API_KEY=your-manychat-api-key
# Shared secret sent from ManyChat External Request nodes as the
# X-ManyChat-Secret header. Leave empty to disable verification (dev only).
MANYCHAT_WEBHOOK_SECRET=replace-with-long-random-string
# Override which Claude model handles real-time ManyChat replies (optional).
CLAUDE_MANYCHAT_MODEL=claude-sonnet-4-20250514
FLODESK_API_KEY=your-flodesk-api-key
# Fallback Flodesk segment ID used when no flodesk_segment_map rule matches.
FLODESK_DEFAULT_SEGMENT=
APIFY_TOKEN=your-apify-token
VIZARD_API_KEY=your-vizard-api-key
PERPLEXITY_API_KEY=your-perplexity-key
